# ============================================================
# MapCore SDK 内部部署配置
# ============================================================
# 此文件是 SDK 项目自身的配置，构建时由 Vite 注入产物。
# 外部调用方不可修改此文件，部署时由运维/构建人员配置。
# ============================================================

# ==================== 二维瓦片资源（OpenLayers）====================

# 默认底图瓦片服务地址（XYZ 格式）
# 支持 {x}、{y}、{z} 占位符
MAPCORE_TILE_BASE=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# 卫星影像瓦片服务地址（可选，如天地图/高德/自定义内网服务）
MAPCORE_SATELLITE_URL=

# WMS 服务地址（可选）
MAPCORE_WMS_URL=

# ==================== 三维资源（Cesium）====================

# Cesium 静态资源基础路径（JS/CSS/Workers/Assets）
# 内网部署时配置为内网文件服务器路径
# 留空则使用 Cesium 默认 CDN
MAPCORE_CESIUM_BASE_URL=

# Cesium Ion 服务地址
# 设为 null 则完全禁用 Ion（离线部署推荐）
# 设为具体 URL 则使用自建 Cesium Ion 服务
MAPCORE_CESIUM_ION=null

# 地形服务地址（DEM 高程数据）
# 内网部署时配置为内网地形服务
MAPCORE_TERRAIN_URL=

# 3D Tiles 服务基础路径（可选）
MAPCORE_TILESET3D_URL=

# ==================== 其他资源 ====================

# GeoServer / 地理信息服务地址（可选，供 WMS/WFS 等使用）
MAPCORE_GEOSERVER_URL=
