{
  "name": "@geomapcore/sdk",
  "version": "1.0.0",
  "description": "MapCore SDK - 统一地图引擎 SDK，支持 2D (OpenLayers) 和 3D (Cesium)",
  "main": "dist/mapcore.umd.js",
  "module": "dist/mapcore.esm.js",
  "types": "dist/index.d.ts",
  "browser": "dist/mapcore.umd.js",
  "exports": {
    ".": {
      "import": "./dist/mapcore.esm.js",
      "require": "./dist/mapcore.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite-plugin.js",
      "types": "./dist/vite-plugin.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && rollup --configPlugin typescript -c rollup.config.ts",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "ol": "^9.0.0",
    "cesium": "^1.120.0",
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ol": {
      "optional": true
    },
    "cesium": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@geomapcore/core": "workspace:*",
    "@geomapcore/adapter-ol": "workspace:*",
    "@geomapcore/adapter-cesium": "workspace:*",
    "@geomapcore/datasource": "workspace:*",
    "@geomapcore/bridge": "workspace:*",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-typescript": "^11.1.0",
    "cesium": "^1.120.0",
    "ol": "^9.0.0",
    "rollup": "^4.9.0",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
